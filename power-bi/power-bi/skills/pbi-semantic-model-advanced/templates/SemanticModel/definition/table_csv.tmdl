table {NomeTabella}

	partition {NomeTabella}-SP = m
		mode: import
		source =
			let
				Source = SharePoint.Files("{LinkSharePoint}", [ApiVersion = 15]),
				File = Source{[Name="{NomeFile}.csv"]}[Content],
				Tabella = Csv.Document(File, [Delimiter=",", Encoding=65001]),
				Intestazioni = Table.PromoteHeaders(Tabella, [PromoteAllScalars=true])
			in
				Intestazioni

	column {NomeColonna1}
		dataType: string
		sourceColumn: {NomeColonna1}


table {NomeTabella}

	partition {NomeTabella}-SP = m
		mode: import
		source =
			let
				Source = SharePoint.Files("{LinkSharePoint}", [ApiVersion = 15]),
				File = Source{[Name="{NomeFile}.xlsx"]}[Content],
				Workbook = Excel.Workbook(File, null, true),
				Foglio = Workbook{[Item="{NomeFoglio}",Kind="Sheet"]}[Data],
				Intestazioni = Table.PromoteHeaders(Foglio, [PromoteAllScalars=true])
			in
				Intestazioni

	column {NomeColonna1}
		dataType: string
		sourceColumn: {NomeColonna1}

	column {NomeColonna2}
		dataType: int64
		sourceColumn: {NomeColonna2}

